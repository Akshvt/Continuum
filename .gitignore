# IDE / OS specific ignores
.code-review-graph/
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Backend specific ignores (also covered by backend/.gitignore)
backend/.env
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/venv/
backend/.venv/
backend/test_venv/
*.venv/
venv/
